datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("VIEWER")
  status       String   @default("ACTIVE")
  records      Record[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Record {
  id        String   @id @default(uuid())
  amount    Float
  type      String
  category  String
  date      DateTime
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
